<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">bitstree_withdrawal_listing.bitstree_withdrawal_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>bitstree_withdrawal_listing_columns</spinner>
        <deps>
            <dep>bitstree_withdrawal_listing.bitstree_withdrawal_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="bitstree_withdrawal_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>BitsTree_Withdrawal::withdrawals</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="bitstree_withdrawal_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="bitstree_withdrawal_listing_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="order_increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Order #</label>
            </settings>
        </column>
        <column name="customer_name" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Name</label>
            </settings>
        </column>
        <column name="customer_email" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select" sortOrder="50">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <options class="BitsTree\Withdrawal\Ui\Component\Listing\Column\Status"/>
                <dataType>select</dataType>
            </settings>
        </column>
        <column name="items_data" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Items</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="70">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Created At</label>
                <dataType>date</dataType>
            </settings>
        </column>
        <actionsColumn name="actions" class="BitsTree\Withdrawal\Ui\Component\Listing\Column\Actions" sortOrder="200">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
