if (!$block->canShowButton()) {
    return;
}

$submitUrl = $block->escapeUrl($block->getSubmitUrl());
$confirmMessage = $block->escapeHtml($block->getConfirmationMessage());
$formKey = $block->getFormKey();
?>
<div x-data="{ showModal: false, submitting: false }" class="inline-block">
    <button type="button"
            class="btn btn-primary bitstree-withdrawal-btn"
            @click="showModal = true">
        <?= $block->escapeHtml(__('Submit Withdrawal')) ?>
    </button>

    <div x-show="showModal"
         x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center"
         @keydown.escape.window="showModal = false">
        <div class="fixed inset-0 bg-black bg-opacity-50" @click="showModal = false"></div>
        <div class="relative bg-white rounded-lg shadow-xl max-w-lg w-full mx-4 p-6 z-10">
            <h3 class="text-lg font-semibold mb-4"><?= $block->escapeHtml(__('Submit Withdrawal')) ?></h3>
            <p class="mb-6"><?= $confirmMessage ?></p>
            <div class="flex justify-end gap-3">
                <button type="button"
                        class="btn btn-secondary"
                        @click="showModal = false">
                    <?= $block->escapeHtml(__('Cancel')) ?>
                </button>
                <button type="button"
                        class="btn btn-primary"
                        :disabled="submitting"
                        @click="
                            submitting = true;
                            const formData = new FormData();
                            formData.append('form_key', '<?= $block->escapeJs($formKey) ?>');
                            fetch('<?= $block->escapeJs($submitUrl) ?>', {
                                method: 'POST',
                                body: formData,
                                credentials: 'same-origin'
                            }).then(response => {
                                window.location.reload();
                            }).catch(() => {
                                submitting = false;
                                showModal = false;
                            });
                        ">
                    <span x-show="!submitting"><?= $block->escapeHtml(__('Submit Withdrawal')) ?></span>
                    <span x-show="submitting"><?= $block->escapeHtml(__('Submitting...')) ?></span>
                </button>
            </div>
        </div>
    </div>
</div>
